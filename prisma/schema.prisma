  FESTIVAL
  PUJA
  VRAT
  JAYANTI
  TITHI
  SANKRANTI
  ECLIPSE
  OTHER
}

enum RecurrenceType {
  NONE
  YEARLY_LUNAR
  YEARLY_SOLAR
  MONTHLY_LUNAR
  MONTHLY_SOLAR
}

/// Event rule type for auto-generation from naming catalog
enum RuleType {
  TITHI
  SOLAR
  NAKSHATRA
  TITHI_NAKSHATRA
  WEEKDAY_TITHI
  PRADOSH
  CUSTOM
}

enum CalendarView {
  month
  week
  day
  agenda
}

