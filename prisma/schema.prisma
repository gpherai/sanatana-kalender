generator client {
  provider = "prisma-client-js"
}

/// How to derive the observation time window for an event occurrence.
/// Times are calculated from DailyInfo sunrise/sunset for that specific date.
enum TimingType {
  NISHITA_KAAL /// Midpoint of the night: sunset + (nextSunrise - sunset) / 2 ± 30min
  PRADOSH_KAAL /// Twilight window: sunset - 90min to sunset + 45min
  SUNRISE      /// Sunrise-based: sunrise to sunrise + 2h
  SUNSET       /// Sunset-based: sunset - 30min to sunset + 1h
}

datasource db {
  provider = "postgresql"
}

/// Category for events (deity-based)
/// Definition source of truth: src/config/categories.ts
model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  icon        String
  color       String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  events      Event[]

  @@index([sortOrder])
}

/// Master event definition
model Event {
  id             String            @id @default(cuid())
  name           String
  description    String?
  eventType      EventType         @default(OTHER)
  recurrenceType RecurrenceType    @default(NONE)
  importance     Importance        @default(MODERATE)
  categoryId     String?
  tithi          Tithi?
  nakshatra      Nakshatra?
  maas           Maas?
  sankranti      Sankranti?
  isAdhikaOnly   Boolean           @default(false)
  includeAdhika  Boolean           @default(false)
  ruleType       RuleType?
  ruleConfig     Json?
  namingKey      String?           @unique
  autoGenerated  Boolean           @default(false)
  tags           String[]          @default([])
  startTime      String?
  endTime        String?
  timingType     TimingType?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  category             Category?             @relation(fields: [categoryId], references: [id])
  occurrences          EventOccurrence[]
  seriesParentEntries  EventSeriesEntry[]    @relation("SeriesParent")
  seriesChildEntries   EventSeriesEntry[]    @relation("SeriesChild")

  @@index([eventType])
  @@index([categoryId])
  @@index([recurrenceType])
  @@index([importance])
  @@index([tags], type: Gin)
}

/// Junction table for many-to-many parent-child event series relationships.
/// Allows one event (e.g. Maa Shailputri) to be a child of multiple parent series
/// (e.g. both Chaitra Navratri and Sharad Navratri).
model EventSeriesEntry {
  id            String   @id @default(cuid())
  parentEventId String
  childEventId  String
  dayNumber     Int?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  parent        Event    @relation("SeriesParent", fields: [parentEventId], references: [id], onDelete: Cascade)
  child         Event    @relation("SeriesChild",  fields: [childEventId],  references: [id], onDelete: Cascade)

  @@unique([parentEventId, childEventId])
  @@index([parentEventId])
  @@index([childEventId])
}

/// Specific occurrence of an event on a date
model EventOccurrence {
  id        String    @id @default(cuid())
  eventId   String
  date      DateTime  @db.Date
  endDate   DateTime? @db.Date
  startTime String?
  endTime   String?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, date])
  @@index([date])
  @@index([endDate])
}

/// Daily astronomical/lunar information
/// This is the source of truth for lunar data per day
model DailyInfo {
  id                   String         @id @default(cuid())
  date                 DateTime       @unique @db.Date
  locationName         String         @default("Den Haag")
  locationLat          Float          @default(52.078525871758096)
  locationLon          Float          @default(4.331036597783044)
  sunrise              String?
  sunset               String?
  moonrise             String?
  moonset              String?
  moonPhasePercent     Int            @default(0)
  moonPhaseType        MoonPhaseType?
  isWaxing             Boolean        @default(true)
  tithi                Tithi?
  tithiEndTime         String?
  nakshatra            Nakshatra?
  nakshatraEndTime     String?
  yogaName             String?
  yogaEndTime          String?
  karanaName           String?
  karanaType           String?
  karanaEndTime        String?
  maas                 Maas?
  paksha               Paksha?
  isAdhika             Boolean        @default(false)
  sankranti            Sankranti?
  sankrantiTime        String?
  maasType             String?
  lunarDay             Int?
  vikramaSamvatYear    Int?
  vikramaSamvatName    String?
  shakaSamvatYear      Int?
  shakaSamvatName      String?
  samvatsaraName       String?
  samvatsaraNumber     Int?
  sunSignNumber        Int?
  sunSignUpto          String?
  moonSignNumber       Int?
  moonSignUpto         String?
  daysSinceSankranti   Int?
  currentRashi         String?
  lastSankrantiDate    DateTime?      @db.Date
  nextTithiNumber      Int?
  nextTithiName        String?
  nextTithiPaksha      String?
  nextTithiEndTime     String?
  nextNakshatraNumber  Int?
  nextNakshatraName    String?
  nextNakshatraPada    Int?
  nextNakshatraEndTime String?
  nextYogaNumber       Int?
  nextYogaName         String?
  nextYogaEndTime      String?
  nextKaranaNumber     Int?
  nextKaranaName       String?
  nextKaranaType       String?
  nextKaranaEndTime    String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([tithi])
  @@index([sankranti])
  @@index([sankranti, date])
}

/// User preferences (single-user for now)
model UserPreference {
  id                     String       @id @default("default")
  currentTheme           String       @default("spiritual-minimal")
  defaultView            CalendarView @default(month)
  weekStartsOn           Int          @default(1)
  timezone               String       @default("Europe/Amsterdam")
  locationName           String       @default("Den Haag")
  locationLat            Float        @default(52.0705)
  locationLon            Float        @default(4.3007)
  visibleEventTypes      EventType[]  @default([])
  visibleCategories      String[]     @default([])
  notificationsEnabled   Boolean      @default(false)
  notificationDaysBefore Int          @default(1)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
}

enum EventType {
  FESTIVAL
  PUJA
  VRAT
  JAYANTI
  TITHI
  SANKRANTI
  ECLIPSE
  OTHER
}

enum RecurrenceType {
  NONE
  YEARLY_LUNAR
  YEARLY_SOLAR
  MONTHLY_LUNAR
  MONTHLY_SOLAR
}

/// Event rule type for auto-generation from naming catalog
enum RuleType {
  TITHI
  SOLAR
  NAKSHATRA
  TITHI_NAKSHATRA
  WEEKDAY_TITHI
  CUSTOM
}

enum Importance {
  MAJOR
  MODERATE
  MINOR
}

enum CalendarView {
  month
  week
  day
  agenda
}

