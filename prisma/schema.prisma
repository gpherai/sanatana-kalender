// =============================================================================
// SADHANA TRACKER
// =============================================================================

enum SadhanaPracticeType {
  mantra_japa
  parayana
  other
}

enum SadhanaItemUnit {
  malas
  count
}

enum SadhanaGoalType {
  daily
  weekly
  lifetime
}

model SadhanaPractice {
  id           String               @id @default(cuid())
  name         String
  type         SadhanaPracticeType
  mantraText   String?
  countSize    Int?
  notes        String?
  active       Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  items        SadhanaSessionItem[]
  routineItems SadhanaRoutineItem[]
  goals        SadhanaGoal[]

  @@map("sadhana_practices")
}

model SadhanaSession {
  id              String               @id @default(cuid())
  date            DateTime             @db.Date
  startedAt       DateTime?
  durationMinutes Int?
  notes           String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  items           SadhanaSessionItem[]

  @@index([date])
  @@map("sadhana_sessions")
}

model SadhanaSessionItem {
  id              String          @id @default(cuid())
  sessionId       String
  practiceId      String
  quantity        Int
  unit            SadhanaItemUnit @default(malas)
  durationMinutes Int?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  session         SadhanaSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  practice        SadhanaPractice @relation(fields: [practiceId], references: [id], onDelete: Restrict)

  @@index([sessionId])
  @@index([practiceId])
  @@map("sadhana_session_items")
}

model SadhanaGoal {
  id            String          @id @default(cuid())
  type          SadhanaGoalType
  name          String?
  targetMalas   Int
  targetMinutes Int?
  active        Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  practices SadhanaPractice[]

  @@map("sadhana_goals")
}

model SadhanaRoutine {
  id        String               @id @default(cuid())
  name      String
  active    Boolean              @default(true)
  sortOrder Int                  @default(0)
  items     SadhanaRoutineItem[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@map("sadhana_routines")
}

model SadhanaRoutineItem {
  id         String          @id @default(cuid())
  routine    SadhanaRoutine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  routineId  String
  practice   SadhanaPractice @relation(fields: [practiceId], references: [id], onDelete: Restrict)
  practiceId String
  quantity   Int
  unit       SadhanaItemUnit @default(malas)
  sortOrder  Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([routineId])
  @@index([practiceId])
  @@map("sadhana_routine_items")
}

/// Solar transitions between zodiac signs (Sankranti)
enum Sankranti {
  MESHA_SANKRANTI
  VRISHABHA_SANKRANTI
  MITHUNA_SANKRANTI
  KARKA_SANKRANTI
  SIMHA_SANKRANTI
  KANYA_SANKRANTI
  TULA_SANKRANTI
  VRISHCHIKA_SANKRANTI
  DHANU_SANKRANTI
  MAKARA_SANKRANTI
  KUMBHA_SANKRANTI
  MEENA_SANKRANTI
}
