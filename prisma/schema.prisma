generator client {
  provider = "prisma-client-js"
}

/// How to derive the observation time window for an event occurrence.
/// Times are calculated from DailyInfo sunrise/sunset for that specific date.
enum TimingType {
  NISHITA_KAAL /// Midpoint of the night: sunset + (nextSunrise - sunset) / 2 ± 30min
  PRADOSH_KAAL /// Twilight window: sunset - 90min to sunset + 45min
  SUNRISE /// Sunrise-based: sunrise to sunrise + 2h
  SUNSET /// Sunset-based: sunset - 30min to sunset + 1h
  MADHYAHNA /// Midday window: 2nd/5th to 3rd/5th of the day (Ganesh Chaturthi puja)
}

datasource db {
  provider = "postgresql"
}

/// Category for events (deity-based)
/// Definition source of truth: src/config/categories.ts
model Category {
  id              String          @id @default(cuid())
  name            String          @unique
  displayName     String
  icon            String
  color           String
  colorDark       String?
  description     String?
  sortOrder       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  eventCategories EventCategory[]

  @@index([sortOrder])
  @@map("categories")
}

/// Master event definition
model Event {
  id                  String             @id @default(cuid())
  name                String
  description         String?
  eventType           EventType          @default(OTHER)
  recurrenceType      RecurrenceType     @default(NONE)
  tithi               Tithi?
  nakshatra           Nakshatra?
  maas                Maas?
  sankranti           Sankranti?
  isAdhikaOnly        Boolean            @default(false)
  includeAdhika       Boolean            @default(false)
  ruleType            RuleType?
  ruleConfig          Json?
  namingKey           String?            @unique
  autoGenerated       Boolean            @default(false)
  tags                String[]           @default([])
  aliases             String[]           @default([])
  startTime           DateTime?          @db.Time
  endTime             DateTime?          @db.Time
  timingType          TimingType?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  categories          EventCategory[]
  occurrences         EventOccurrence[]
  seriesParentEntries EventSeriesEntry[] @relation("SeriesParent")
  seriesChildEntries  EventSeriesEntry[] @relation("SeriesChild")

  @@index([eventType])
  @@index([recurrenceType])
  @@index([tags], type: Gin)
  @@map("events")
}

/// Join table for Event ↔ Category many-to-many.
/// sortOrder=0 is the primary category (used for color/icon on calendar).
model EventCategory {
  id         String   @id @default(cuid())
  eventId    String
  categoryId String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@unique([eventId, categoryId])
  @@index([eventId, sortOrder])
  @@index([categoryId])
  @@map("event_categories")
}

/// Junction table for many-to-many parent-child event series relationships.
/// Allows one event (e.g. Maa Shailputri) to be a child of multiple parent series
/// (e.g. both Chaitra Navratri and Sharad Navratri).
model EventSeriesEntry {
  id            String   @id @default(cuid())
  parentEventId String
  childEventId  String
  dayNumber     Int?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  parent        Event    @relation("SeriesParent", fields: [parentEventId], references: [id], onDelete: Cascade)
  child         Event    @relation("SeriesChild", fields: [childEventId], references: [id], onDelete: Cascade)

  @@unique([parentEventId, childEventId])
  @@index([parentEventId])
  @@index([childEventId])
  @@map("event_series_entries")
}

/// Specific occurrence of an event on a date
model EventOccurrence {
  id        String    @id @default(cuid())
  eventId   String
  date      DateTime  @db.Date
  endDate   DateTime? @db.Date
  startTime DateTime? @db.Time
  endTime   DateTime? @db.Time
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, date])
  @@index([date])
  @@index([endDate])
  @@map("event_occurrences")
}

/// Daily astronomical/lunar information
/// This is the source of truth for lunar data per day
model DailyInfo {
  id                   String         @id @default(cuid())
  date                 DateTime       @unique @db.Date
  locationName         String
  locationLat          Float
  locationLon          Float
  sunrise              DateTime?      @db.Time
  sunset               DateTime?      @db.Time
  moonrise             DateTime?      @db.Time
  moonset              DateTime?      @db.Time
  moonriseUtcIso       String?
  moonsetUtcIso        String?
  moonPhasePercent     Int            @default(0)
  moonPhaseType        MoonPhaseType?
  isWaxing             Boolean        @default(true)
  tithi                Tithi?
  tithiEndTime         DateTime?      @db.Time
  nakshatra            Nakshatra?
  nakshatraEndTime     DateTime?      @db.Time
  yogaName             String?
  yogaEndTime          DateTime?      @db.Time
  karanaName           String?
  karanaType           String?
  karanaEndTime        DateTime?      @db.Time
  maas                 Maas?
  paksha               Paksha?
  isAdhika             Boolean        @default(false)
  sankranti            Sankranti?
  sankrantiTime        DateTime?      @db.Time
  maasType             String?
  lunarDay             Int?
  vikramaSamvatYear    Int?
  vikramaSamvatName    String?
  shakaSamvatYear      Int?
  shakaSamvatName      String?
  samvatsaraName       String?
  samvatsaraNumber     Int?
  sunSignNumber        Int?
  sunSignUpto          DateTime?      @db.Time
  moonSignNumber       Int?
  moonSignUpto         DateTime?      @db.Time
  daysSinceSankranti   Int?
  currentRashi         String?
  lastSankrantiDate    DateTime?      @db.Date
  nextTithiNumber      Int?
  nextTithiName        String?
  nextTithiPaksha      String?
  nextTithiEndTime     DateTime?      @db.Time
  nextNakshatraNumber  Int?
  nextNakshatraName    String?
  nextNakshatraPada    Int?
  nextNakshatraEndTime DateTime?      @db.Time
  nextYogaNumber       Int?
  nextYogaName         String?
  nextYogaEndTime      DateTime?      @db.Time
  nextKaranaNumber     Int?
  nextKaranaName       String?
  nextKaranaType       String?
  nextKaranaEndTime    DateTime?      @db.Time
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([tithi])
  @@index([sankranti])
  @@index([sankranti, date])
  @@map("daily_info")
}

/// User preferences (single-user for now)
model UserPreference {
  id                     String       @id @default("default")
  currentTheme           String       @default("spiritual-minimal")
  defaultView            CalendarView @default(month)
  visibleEventTypes      EventType[]  @default([])
  visibleCategories      String[]     @default([])
  notificationsEnabled   Boolean      @default(false)
  notificationDaysBefore Int          @default(1)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  @@map("user_preferences")
}

