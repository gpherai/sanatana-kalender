# =============================================================================
# Sanatana Kalender - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# Database Settings (PostgreSQL 17+)
DATABASE_URL="postgresql://user:password@localhost:5432/dharma_db?schema=public"

# Docker/Podman Database Credentials (used by docker-compose for local DB container)
POSTGRES_USER="user"
POSTGRES_PASSWORD="password"
POSTGRES_DB="dharma_db"

# App Settings - Default panchanga calculation location
DEFAULT_LOCATION_LAT="52.0705"
DEFAULT_LOCATION_LON="4.3007"
DEFAULT_LOCATION_NAME="Den Haag"
