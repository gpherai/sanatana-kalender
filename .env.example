# =============================================================================
# Sanatana Kalender - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# Database Settings (PostgreSQL 17+)
DATABASE_URL="postgresql://user:password@localhost:5432/dharma_db?schema=public"

# Docker/Podman Database Credentials (used by docker-compose for local DB container)
POSTGRES_USER="user"
POSTGRES_PASSWORD="password"
POSTGRES_DB="dharma_db"

# OpenWeather API key for current weather, 5-day forecast, map tiles, air pollution
# and optional OpenWeather Alerts API access. The app does not use One Call.
OPENWEATHER_API_KEY=""
